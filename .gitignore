# Ignore everything at root
/*

# Allow only these directories and files
!/backend/
!/database/
!/frontend/
!/.gitignore
!/README.md

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/

# ── Environments / secrets ──
.env
.env.*
.venv/
venv/
ENV/
instance/
backend/client_secret_*.json
backend/token.pickle

# ── Node / frontend build artifacts ──
node_modules/
dist/
dist-ssr/
build/
.vite/
.esbuild/
.cache/
.next/
out/
coverage/
parcel-cache/
.pnp/
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun.lockb

# ── IDE / OS ──
.vscode/
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ──
*.log
*.tmp
*.temp
logs/